# ───────────────────────────────────────────────────────────────────────
# EA Arch Agent — environment configuration
# Copy this to `.env` and fill in any values you want to override.
# ───────────────────────────────────────────────────────────────────────

# ── Ollama ─────────────────────────────────────────────────────────────
# Inside docker-compose, OLLAMA_HOST resolves to http://ollama:11434
# automatically (overridden by docker-compose.yml). Set this only if
# running the backend outside Compose.
OLLAMA_HOST=http://localhost:11434

# Model tag pulled by ollama-pull and used by the backend client.
# Multimodal Gemma 4. The user already has gemma4:latest (~9.6 GB).
OLLAMA_MODEL=gemma4:26b

# Pin the model in VRAM indefinitely. Set to a value like "30m" if you
# want it to unload after idle time on memory-constrained hosts.
OLLAMA_KEEP_ALIVE=-1

# ── Backend ────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# Comma-separated list of allowed CORS origins. Must be exact-origin
# (no wildcards) when using credentials.
CORS_ORIGINS=http://localhost:5173,http://localhost

# Path prefix the app is mounted under (must match Vite base + nginx).
BASE_PATH=/arch-assistant

# Max upload size enforced server-side (bytes). 15 MB = 15728640.
MAX_UPLOAD_BYTES=15728640

# Image preprocessing — longest edge in pixels (matches Gemma vision tile).
IMAGE_RESIZE_MAX_EDGE=1568

# ── Frontend ───────────────────────────────────────────────────────────
FRONTEND_PORT=5173

# ── Database (Postgres) ────────────────────────────────────────────────
POSTGRES_USER=kpmg
POSTGRES_PASSWORD=kpmg
POSTGRES_DB=kpmg_arch
# Resolved automatically inside Compose to point at the `db` service.
DATABASE_URL=postgresql+asyncpg://kpmg:kpmg@localhost:5432/kpmg_arch

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
