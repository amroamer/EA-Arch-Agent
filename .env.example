# ─────────────────────────────────────────────────────────────────────────
# EA Arch Agent — environment reference
#
# This file is the human-readable catalogue of every env var the app
# touches. The actual config lives in:
#
#   .env          — committed, prod defaults (see "Resolution order" below)
#   .env.local    — gitignored, personal local overrides
#
# The kpmg-infra orchestrator injects DATABASE_URL and OLLAMA_HOST as
# process env at container start; the others are read from .env / .env.local.
#
# Resolution order (highest priority wins):
#   1. Process env (orchestrator-injected; docker-compose `environment:`)
#   2. .env.local
#   3. .env
#
# Legend:
#   [ORCH]      — Production: injected by kpmg-infra. Do NOT set in .env.
#   [REQUIRED]  — App will fail-fast on startup if empty/placeholder.
#   [OPTIONAL]  — Has a sensible default; warn-on-placeholder only.
# ─────────────────────────────────────────────────────────────────────────


# ── Ollama ───────────────────────────────────────────────────────────────

# [ORCH] [REQUIRED]
# Base URL of the Ollama daemon. In prod, kpmg-infra injects this so
# the backend can reach the shared host Ollama (typically
# `http://ollama-shared:11434` on the kpmg-network). In local dev,
# docker-compose.yml's `environment:` block sets it to `http://ollama:11434`
# pointing at the in-compose ollama service.
# Default if unset: `http://ollama:11434`.
OLLAMA_HOST=http://ollama-shared:11434

# [REQUIRED]
# Model tag to use. Must match a model present on the target Ollama
# daemon (`ollama list`). Currently shipping with qwen2.5vl:7b for its
# vision support and 7B speed; gemma4:26b also works (older, slower).
OLLAMA_MODEL=qwen2.5vl:7b

# [OPTIONAL]
# How long Ollama keeps the model in VRAM after the last request.
# `-1` = forever (recommended for prod — eliminates cold-start latency).
# `30m` = unload after 30 minutes idle. `0` = unload immediately.
OLLAMA_KEEP_ALIVE=-1


# ── Database ─────────────────────────────────────────────────────────────

# [ORCH] [REQUIRED]
# SQLAlchemy async DSN. Injected by kpmg-infra in prod (typically pointing
# at the shared Postgres on the VM). In local dev, docker-compose.yml
# computes it from POSTGRES_USER/PASSWORD/DB below. Format:
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Default if unset: `postgresql+asyncpg://kpmg:kpmg@db:5432/kpmg_arch`.
DATABASE_URL=postgresql+asyncpg://USER:CHANGE_ME_IN_PRODUCTION@db:5432/kpmg_arch


# ── App routing ──────────────────────────────────────────────────────────

# [OPTIONAL]
# URL prefix the app is mounted under. Must match the Vite `base` config
# AND the nginx routing in /etc/nginx on the deploy VM.
BASE_PATH=/EAArchAgent

# [OPTIONAL]
# Comma-separated CORS allow-list (exact origins, no wildcards — SSE
# consumers use `credentials: 'include'`). Add localhost origins in
# .env.local for local dev.
CORS_ORIGINS=https://arch-assistant.kpmg.example


# ── Upload limits ────────────────────────────────────────────────────────

# [OPTIONAL]
# Maximum bytes accepted by /analyze per upload (15 MB).
MAX_UPLOAD_BYTES=15728640

# [OPTIONAL]
# Longest edge in pixels after server-side image resize. Tuned to the
# vision model's preferred tile size; larger values slow inference.
IMAGE_RESIZE_MAX_EDGE=1568


# ── Logging ──────────────────────────────────────────────────────────────

# [OPTIONAL]
# DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO


# ── Compose-only (NOT read by the backend) ───────────────────────────────
# Used by docker-compose.yml to provision the local Postgres container
# and assign host ports. Production deploys ignore these — kpmg-infra
# manages Postgres separately and injects DATABASE_URL.

# [OPTIONAL] Postgres credentials baked into the docker-compose `db`
# service. Match the username/password embedded in the dev DATABASE_URL.
# These are NOT real secrets — local-only, dev-network-only.
POSTGRES_USER=kpmg
POSTGRES_PASSWORD=kpmg
POSTGRES_DB=kpmg_arch

# [OPTIONAL] Host port mappings for `docker compose up -d`. Useful when
# 8000 or 5173 are already taken on your machine.
BACKEND_PORT=8000
FRONTEND_PORT=5173
