# ── Environment & secrets ─────────────────────────────────────────────
# .env IS committed — it holds public-facing defaults. The kpmg-infra
# deploy mounts it via env_file: /opt/apps/EA-Arch-Agent/.env so the
# file must exist at the repo root. Real secrets live in either
# kpmg-infra's env-injection layer (production) or .env.local (dev).
#
# The .env.* files below are gitignored — used for personal local
# overrides and one-off environment-specific tweaks.
.env.local
.env.*.local
.env.production
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ── Node / Frontend ───────────────────────────────────────────────────
node_modules/
.pnp.*
.npm/
.yarn/
.parcel-cache/
.next/
.vite/
dist-ssr/

# ── Build outputs ─────────────────────────────────────────────────────
frontend/dist/
backend/dist/

# ── Docker volumes (mapped in compose) ─────────────────────────────────
ollama_data/
postgres_data/

# ── Editor / OS ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local test artifacts ──────────────────────────────────────────────
test_diagram*.png
test_diagram*.jpg
test_diagram*.jpeg
*.tmp

# ── Plan files (kept outside repo) ────────────────────────────────────
.claude/
