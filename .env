# ─────────────────────────────────────────────────────────────────────────
# EA Arch Agent — committed environment defaults
#
# This file IS checked into git. The kpmg-infra deploy mounts it via
#   env_file: /opt/apps/EA-Arch-Agent/.env
# so the file must exist at the repo root.
#
# Resolution order (highest priority wins):
#   1. Process env injected by kpmg-infra at runtime
#      (DATABASE_URL, OLLAMA_HOST — see "Orchestrator-injected" below)
#   2. .env.local — gitignored, for personal local overrides
#   3. .env — this file
#
# DO NOT add real secrets here. Anything sensitive belongs in either:
#   - the orchestrator's env-injection layer (production), or
#   - .env.local (local development; gitignored).
# ─────────────────────────────────────────────────────────────────────────


# ── Orchestrator-injected (do NOT set here) ──────────────────────────────
# In production, kpmg-infra injects these at container start. Setting them
# here would shadow the orchestrator and is almost certainly wrong.
# In local dev, docker-compose.yml's `environment:` block sets them
# directly so this file doesn't need them either.
#
# DATABASE_URL=postgresql+asyncpg://kpmg:CHANGE_ME_IN_PRODUCTION@db:5432/kpmg_arch
# OLLAMA_HOST=http://ollama-shared:11434


# ── Application config ───────────────────────────────────────────────────
# These are read by the backend's Pydantic Settings on startup.

# Model name as recognised by the shared Ollama daemon.
OLLAMA_MODEL=qwen2.5vl:7b

# -1 = pin model in VRAM forever (eliminates cold-start latency).
OLLAMA_KEEP_ALIVE=-1

# URL prefix the app is mounted under. Must match nginx routing on the VM.
BASE_PATH=/EAArchAgent

# Comma-separated allow-list of HTTPS origins permitted by CORS.
# Wildcards forbidden (SSE consumers may use `credentials: 'include'`).
# For local dev, .env.local typically overrides this with localhost values.
CORS_ORIGINS=https://arch-assistant.kpmg.example

# Maximum bytes the /analyze endpoint will accept per upload (15 MB).
MAX_UPLOAD_BYTES=15728640

# Longest edge in pixels after server-side image resize. Tuned to the
# vision model's preferred tile size.
IMAGE_RESIZE_MAX_EDGE=1568

# DEBUG | INFO | WARNING | ERROR. INFO is the production default.
LOG_LEVEL=INFO


# ── Compose-only (used by docker-compose.yml; not read by the backend) ──
# These provision the local Postgres container during development. In
# production the orchestrator runs Postgres separately and injects
# DATABASE_URL — these values are ignored.
#
# The values below match the credentials baked into the dev
# `database_url` default, so the local docker-compose `db` service comes
# up with creds the backend can connect to. They are NOT secrets in any
# real sense (only reachable inside the docker network).
POSTGRES_USER=kpmg
POSTGRES_PASSWORD=kpmg
POSTGRES_DB=kpmg_arch

# Host port mappings for `docker compose up -d`. Override locally if
# something else is bound to 8000 / 5173.
BACKEND_PORT=8000
FRONTEND_PORT=5173
