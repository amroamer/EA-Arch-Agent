# Production environment overrides — copy to .env.production and fill in.

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_KEEP_ALIVE=-1

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Exact-origin allow-list (no wildcards). Use the public HTTPS URL.
CORS_ORIGINS=https://arch-assistant.kpmg.example

BASE_PATH=/arch-assistant
MAX_UPLOAD_BYTES=15728640
IMAGE_RESIZE_MAX_EDGE=1568

# Postgres — supply real secrets in the actual .env.production file.
POSTGRES_USER=arch
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=arch
DATABASE_URL=postgresql+asyncpg://arch:__CHANGE_ME__@db:5432/arch

LOG_LEVEL=INFO
